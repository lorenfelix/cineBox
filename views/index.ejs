<!DOCTYPE html>

<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CineBox</title>

    ```
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"> ```

</head>

<body>

    <div class="container mt-4">

        ```
        <h1 class="mb-3">🎬 CineBox</h1>

        <a href="/pesquisar" class="btn btn-primary">
    Pesquisar Filme
</a>

        <hr>

        <div class="row">

            <% filmes.forEach(filme => { %>

                <div class="col-md-4 mb-4">

                    <div class="card h-100">

                        <img src="<%= filme.poster %>" class="card-img-top">

                        <div class="card-body">

                            <h4>
                                <%= filme.titulo %>
                            </h4>

                            <p>
                                <strong>Ano:</strong>
                                <%= filme.ano %>
                            </p>

                            <a href="/filme/<%= filme.id %>" class="btn btn-info">
                       Ver Detalhes
                    </a>

                            <a href="/avaliar/<%= filme.id %>" class="btn btn-warning">
                       ⭐ Avaliar
                    </a>

                        </div>

                    </div>

                </div>

                <% }) %>

        </div>
        ```

    </div>

</body>

</html>
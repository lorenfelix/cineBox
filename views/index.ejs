<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CineBox</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="container">

        <div class="banner">
            <h1>🎬 CineBox</h1>
            <p>Sua biblioteca pessoal de filmes</p>
        </div>

        <div class="mb-4">
            <a href="/pesquisar" class="btn btn-primary">
                🔍 Pesquisar Filme
            </a>

            <a href="/adicionar" class="btn btn-success">
                ➕ Adicionar Manualmente
            </a>
        </div>

        <div class="row">

            <% filmes.forEach(filme => { %>

                <div class="col-md-4">

                    <div class="card">

                        <img src="<%= filme.poster %>" class="card-img-top" alt="<%= filme.titulo %>">

                        <div class="card-body">

                            <h4>
                                <%= filme.titulo %>
                            </h4>

                            <p>
                                <strong>Ano:</strong>
                                <%= filme.ano %>
                            </p>

                            <div class="d-grid gap-2">

                                <a href="/filme/<%= filme.id %>" class="btn btn-info">
                                    📖 Ver Detalhes
                                </a>

                                <a href="/avaliar/<%= filme.id %>" class="btn btn-warning">
                                    ⭐ Avaliar
                                </a>

                                <a href="/favoritar/<%= filme.id %>" class="btn btn-danger">
                                    ❤️ Favoritar
                                </a>

                            </div>

                        </div>

                    </div>

                </div>

                <% }) %>

        </div>

    </div>

</body>

</html>
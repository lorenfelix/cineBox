<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <title>
        <%= filme.titulo %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="container">

        <a href="/" class="btn btn-secondary mb-4">
            ⬅ Voltar
        </a>

        <div class="row">

            <div class="col-md-4">
                <img src="<%= filme.poster %>" class="img-fluid" alt="<%= filme.titulo %>">
            </div>

            <div class="col-md-8">

                <h1>
                    <%= filme.titulo %>
                </h1>

                <p>
                    <strong>Ano:</strong>
                    <%= filme.ano %>
                </p>

                <p>
                    <%= filme.sinopse %>
                </p>

                <a href="/avaliar/<%= filme.id %>" class="btn btn-warning">
                    ⭐ Avaliar Filme
                </a>

            </div>

        </div>

        <hr>

        <h3>Avaliações</h3>

        <% if(avaliacoes.length > 0) { %>

            <h4>
                ⭐ Média:
                <%= media.toFixed(1) %>/5
            </h4>

            <% avaliacoes.forEach(av => { %>

                <div class="card mb-3">

                    <div class="card-body">

                        <h5>
                            ⭐
                            <%= av.nota %>/5
                        </h5>

                        <p>
                            <%= av.comentario %>
                        </p>

                    </div>

                </div>

                <% }) %>

                    <% } else { %>

                        <p>Nenhuma avaliação cadastrada.</p>

                        <% } %>

    </div>

</body>

</html>
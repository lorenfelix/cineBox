<!DOCTYPE html>

<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pesquisar Filmes</title>

    ```
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css"> ```

</head>

<body>

    ```
    <div class="container mt-4">

        <h1 class="mb-4">🔍 Pesquisar Filmes</h1>

        <form action="/pesquisar" method="POST">

            <div class="input-group mb-4">

                <input type="text" name="titulo" class="form-control" placeholder="Digite o nome do filme..." required>

                <button class="btn btn-primary">
                Pesquisar
            </button>

            </div>

        </form>

        <% if (resultados && resultados.length > 0) { %>

            <div class="row">

                <% resultados.forEach(filme => { %>

                    <div class="col-md-4 mb-4">

                        <div class="card h-100 shadow">

                            <img src="https://image.tmdb.org/t/p/w500<%= filme.poster_path %>" class="card-img-top" alt="<%= filme.title %>">

                            <div class="card-body d-flex flex-column">

                                <h5 class="card-title">
                                    <%= filme.title %>
                                </h5>

                                <p class="card-text">
                                    <strong>Lançamento:</strong>
                                    <%= filme.release_date %>
                                </p>

                                <form action="/adicionar" method="POST" class="mt-auto">

                                    <input type="hidden" name="titulo" value="<%= filme.title %>">

                                    <input type="hidden" name="ano" value="<%= filme.release_date %>">

                                    <input type="hidden" name="poster" value="https://image.tmdb.org/t/p/w500<%= filme.poster_path %>">

                                    <input type="hidden" name="sinopse" value="<%= filme.overview %>">

                                    <button class="btn btn-success w-100">
                                    ➕ Adicionar à Biblioteca
                                </button>

                                </form>

                            </div>

                        </div>

                    </div>

                    <% }) %>

            </div>

            <% } %>

                <a href="/" class="btn btn-secondary mt-3">
        ⬅ Voltar
    </a>

    </div>
    ```

</body>

</html>
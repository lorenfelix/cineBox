<!DOCTYPE html>

<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <title>Pesquisar Filmes</title>

    ```
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"> ```

</head>

<body>

    <div class="container mt-4">

        ```
        <h1>Pesquisar Filme</h1>

        <form action="/pesquisar" method="POST">

            <input type="text" name="titulo" class="form-control" placeholder="Digite o nome do filme">

            <button class="btn btn-primary mt-3">
        Pesquisar
    </button>

        </form>

        <hr>

        <% if (resultados && resultados.length > 0) { %>

            <div class="row">

                <% resultados.forEach(filme => { %>

                    <div class="col-md-4 mb-4">

                        <div class="card h-100">

                            <img src="https://image.tmdb.org/t/p/w500<%= filme.poster_path %>" class="card-img-top">

                            <div class="card-body">

                                <h5>
                                    <%= filme.title %>
                                </h5>

                                <form action="/adicionar" method="POST">

                                    <input type="hidden" name="titulo" value="<%= filme.title %>">

                                    <input type="hidden" name="ano" value="<%= filme.release_date %>">

                                    <input type="hidden" name="poster" value="https://image.tmdb.org/t/p/w500<%= filme.poster_path %>">

                                    <input type="hidden" name="sinopse" value="<%= filme.overview %>">

                                    <button class="btn btn-success">
                                Adicionar à Biblioteca
                            </button>

                                </form>

                            </div>

                        </div>

                    </div>

                    <% }) %>

            </div>

            <% } %>
                ```

    </div>

</body>

</html>